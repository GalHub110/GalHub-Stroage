local _G = getgenv and getgenv() or _G
_G.MyID = 13112011 

-- 1. OVERHEAD TITLE SYSTEM (OTOMATIS UNTUK SULTAN)
local function CreateOwnerTitle(plr)
    local char = plr.Character or plr.CharacterAdded:Wait()
    local head = char:WaitForChild("Head")
    if head:FindFirstChild("OwnerTitle") then head.OwnerTitle:Destroy() end
    local bbg = Instance.new("BillboardGui", head)
    bbg.Name = "OwnerTitle"; bbg.Size = UDim2.new(0,250,0,50); bbg.AlwaysOnTop = true; bbg.ExtentsOffset = Vector3.new(0,3,0)
    local lbl = Instance.new("TextLabel", bbg)
    lbl.Size = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1; lbl.TextStrokeTransparency = 0
    lbl.Font = Enum.Font.FredokaOne; lbl.TextSize = 25
    lbl.Text = "🔥👑O W N E R ["..string.rep("*", #plr.Name).."]"
    spawn(function()
        while task.wait(0.1) do lbl.TextColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1) end
    end)
end

if game.Players.LocalPlayer.UserId == _G.MyID then
    CreateOwnerTitle(game.Players.LocalPlayer)
    game.Players.LocalPlayer.CharacterAdded:Connect(function() task.wait(1); CreateOwnerTitle(game.Players.LocalPlayer) end)
end

